{
  "AllowedHosts": "*",
  "AppBase": {
    "BasePath": "expensemanagement",
    "ConnectionStrings": {
      "Db": "Server=localhost;Database=ExpenseManagementDb;User Id=sa;Password=YourStrong!Password;TrustServerCertificate=True;"
    }
  },
  "Swagger": {
    "Enabled": false,
    "Title": "Expense Management",
    "Description": "An ASP.NET Core Web API for managing expenses."
  },
  "HttpPort": 5050,
  "Jwt": {
    "PubKey": "my-public-key",
    "Issuer": "https://your-auth-server.com",
    "Audience": "expense-management-api"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "OutputTemplate": "{Timestamp:o} [{Level}] {Message}{NewLine}{Exception}"
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "Application": "expensemanagement"
    }
  }
}
